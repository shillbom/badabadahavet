# Set VITE_USE_FIREBASE_EMULATORS=1 to point at local emulators (default during dev).
VITE_USE_FIREBASE_EMULATORS=1

# These are read at build time. Safe placeholders work for emulator-only dev.
VITE_FIREBASE_API_KEY=demo-key
# Use your Firebase Hosting domain (e.g. yourapp.web.app), NOT firebaseapp.com.
# This ensures the auth handler runs same-origin, avoiding cross-origin storage issues.
VITE_FIREBASE_AUTH_DOMAIN=demo-badabadahavet.web.app
VITE_FIREBASE_PROJECT_ID=demo-badabadahavet
VITE_FIREBASE_STORAGE_BUCKET=demo-badabadahavet.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
# Optional — enables Firebase Analytics in production-style builds.
VITE_FIREBASE_MEASUREMENT_ID=
# Optional — Google Perspective API key for client-side moderation of names
# and notes (restrict it to the Comment Analyzer API + your domains, like the
# Firebase key). Empty = client-side checks are skipped; the logSession Cloud
# Function still enforces moderation via the PERSPECTIVE_API_KEY secret.
VITE_PERSPECTIVE_API_KEY=
