{
  "name": "badligan",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "emulators": "firebase emulators:start",
    "seed:badplatser": "node scripts/seed-badplatser.mjs",
    "seed:eea": "node scripts/seed-eea-bathing.mjs",
    "seed:naturist": "node scripts/seed-naturist-spots.mjs",
    "seed:naturkartan": "node scripts/seed-naturkartan.mjs",
    "update:temperatures": "node scripts/update-temperatures.mjs",
    "scrub:usernames": "node scripts/scrub-usernames.mjs",
    "backfill:scores": "node scripts/backfill-scores.mjs",
    "backfill:thumbnails": "node scripts/backfill-thumbnails.mjs",
    "merge:places": "node scripts/merge-places.mjs",
    "prepare": "husky",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^12.16.0",
    "framer-motion": "^12.42.2",
    "glin-profanity": "^3.3.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.24.0",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "react-router": "^8.2.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "firebase-admin": "^14.1.0",
    "husky": "^9.1.7",
    "jimp": "^1.6.1",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-doctor": "^0.7.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,css}": "prettier --check",
    "*.{ts,tsx}": [
      "oxlint",
      "bash -c 'tsc -b --noEmit'"
    ]
  }
}
