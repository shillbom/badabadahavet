*.log

# Firebase
.firebase/
firestore-debug.log
ui-debug.log
firebase-debug.log
emulator-data/

# Service-account credentials — never commit these.
*-firebase-adminsdk-*.json
*.serviceaccount.json
service-account*.json

# Capacitor — these are regenerated by `cap sync` on every build.
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
ios/App/App/public/
ios/App/App/capacitor.config.json
ios/App/App/capacitor.plugins.json

# Per-environment Firebase config for the native apps. Download these
# from the Firebase Console (Project settings → "Your apps") and drop
# them in here — they're project-specific, not secret, but live outside
# version control so dev/staging/prod stay clean.
android/app/google-services.json
ios/App/App/GoogleService-Info.plist
