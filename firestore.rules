rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Users: anyone signed in can read profiles (for leaderboards). Only the owner writes.
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // Places: any signed-in user can read or create places. Only the creator can update.
    match /places/{placeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if signedIn() && resource.data.createdBy == request.auth.uid;
      allow delete: if false;
    }

    // Sessions: any signed-in user can read (for leaderboards). Only the owner writes.
    match /sessions/{sessionId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Groups: any signed-in user can read & join. Only members can update membership.
    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;
      allow update: if signedIn() && (
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );
      allow delete: if false;
    }
  }
}
