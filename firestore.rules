rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- helpers --------
    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function isAdminUser() {
      return signedIn()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    function unchanged(field) {
      return !changedKeys().hasAny([field]);
    }
    // Returns true when the only change to the reactions map is that
    // request.auth.uid was added to, or removed from, exactly one emoji key.
    function onlyOwnReactionChanged() {
      let myUid = request.auth.uid;
      let oldR = resource.data.get('reactions', {});
      let newR = request.resource.data.get('reactions', {});
      let changed = newR.diff(oldR).affectedKeys();
      return changed.size() == 1
        && validReactionDelta(changed.toList()[0], oldR, newR, myUid);
    }
    function validReactionDelta(emoji, oldR, newR, myUid) {
      let oldSet = oldR.get(emoji, []).toSet();
      let newSet = newR.get(emoji, []).toSet();
      // Added own uid — nothing else changed
      return (newSet.difference(oldSet) == [myUid].toSet()
              && oldSet.difference(newSet).size() == 0)
          // Removed own uid — nothing else changed
          || (oldSet.difference(newSet) == [myUid].toSet()
              && newSet.difference(oldSet).size() == 0);
    }
    function validLatLng(lat, lng) {
      return lat is number && lng is number
             && lat >= -90 && lat <= 90
             && lng >= -180 && lng <= 180;
    }

    // ============================================================
    // users/{uid}
    //   Profile + denormalised group list + unlocked achievements.
    //   Only the owner may write. Identity (uid), createdAt, and
    //   isAdmin are immutable after create — and isAdmin can never
    //   be flipped to true by a client; flip it manually in the
    //   Firebase console / firestore CLI.
    // ============================================================
    match /users/{uid} {
      allow read: if signedIn();

      allow create: if isSelf(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() > 0
                    && request.resource.data.displayName.size() <= 40
                    && request.resource.data.createdAt is number
                    && (
                      !('isAdmin' in request.resource.data)
                      || request.resource.data.isAdmin == false
                    );

      allow update: if isSelf(uid)
                    && unchanged('uid')
                    && unchanged('createdAt')
                    && unchanged('isAdmin')
                    && request.resource.data.uid == uid
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() > 0
                    && request.resource.data.displayName.size() <= 40
                    && (
                      !('lastLocation' in request.resource.data)
                      || (validLatLng(request.resource.data.lastLocation.lat,
                                      request.resource.data.lastLocation.lng))
                    )
                    && (
                      !('toswim' in request.resource.data)
                      || (request.resource.data.toswim is map
                          && request.resource.data.toswim.size() <= 200)
                    );

      // Account deletion: the owner may wipe their own user doc as part
      // of the "delete my account" flow. Admins are intentionally not
      // allowed here — they should moderate via sessions/places.
      allow delete: if isSelf(uid);
    }

    // ============================================================
    // places/{id}
    //   World-readable so logged-out visitors can browse. Admins may
    //   rename/delete for moderation.
    // ============================================================
    match /places/{placeId} {
      allow read: if true;

      allow create: if signedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 80
                    && validLatLng(request.resource.data.lat,
                                   request.resource.data.lng)
                    && request.resource.data.firstSwumAt is number;

      // Creator can rename (only); admins can change anything (still
      // can't move a pin out of bounds because of the basic shape).
      allow update: if (
        signedIn()
        && resource.data.createdBy == request.auth.uid
        && unchanged('createdBy')
        && unchanged('firstSwumAt')
        && unchanged('lat')
        && unchanged('lng')
        && unchanged('id')
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
      ) || isAdminUser();

      // Only admins can delete.
      allow delete: if isAdminUser();
    }

    // ============================================================
    // sessions/{id}
    //   World-readable so logged-out visitors can browse swim history.
    // ============================================================
    match /sessions/{sessionId} {
      allow read: if true;

      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.placeId is string
                    && request.resource.data.placeId.size() > 0
                    && request.resource.data.placeName is string
                    && request.resource.data.placeName.size() <= 80
                    && validLatLng(request.resource.data.lat,
                                   request.resource.data.lng)
                    && request.resource.data.date is number
                    && request.resource.data.date >= 946684800000
                    && request.resource.data.date <= request.time.toMillis() + 86400000
                    && request.resource.data.points is number
                    && request.resource.data.points >= 0
                    && request.resource.data.points <= 15
                    && request.resource.data.isUniqueForUser is bool
                    && request.resource.data.isWinter is bool
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() <= 40;

      // Owners can edit cosmetic fields only; admins can moderate (e.g.
      // strip a bad photoUrl, fix a placeName after a rename).
      // Any signed-in user may update only the reactions map.
      allow update: if (
        signedIn()
        && resource.data.uid == request.auth.uid
        && unchanged('uid')
        && unchanged('placeId')
        && unchanged('lat')
        && unchanged('lng')
        && unchanged('date')
        && unchanged('points')
        && unchanged('isUniqueForUser')
        && unchanged('isWinter')
        && unchanged('createdAt')
      ) || (
        signedIn()
        && changedKeys().hasOnly(['reactions'])
        && onlyOwnReactionChanged()
      ) || isAdminUser();

      allow delete: if (signedIn() && resource.data.uid == request.auth.uid)
                    || isAdminUser();
    }

    // ============================================================
    // groups/{id}
    //   Reads are restricted to current members. Joining is performed
    //   server-side by the `joinGroupByCode` Cloud Function (Admin SDK
    //   bypasses these rules), so the client never needs to read a
    //   group it isn't already part of.
    // ============================================================
    match /groups/{groupId} {
      allow read: if signedIn()
                  && request.auth.uid in resource.data.members;

      allow create: if signedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.members is list
                    && request.resource.data.members.size() == 1
                    && request.resource.data.members[0] == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 60
                    && request.resource.data.code is string
                    && request.resource.data.code.size() >= 3
                    && request.resource.data.code.size() <= 12
                    && request.resource.data.createdAt is number;

      allow update: if signedIn() && (
        // Member voluntarily leaves.
        (
          changedKeys().hasOnly(['members'])
          && request.auth.uid in resource.data.members
          && !(request.auth.uid in request.resource.data.members)
          && resource.data.members.hasAll(request.resource.data.members)
          && request.resource.data.members.size()
             == resource.data.members.size() - 1
        )
        ||
        // Creator renames or changes emoji.
        (
          resource.data.createdBy == request.auth.uid
          && changedKeys().hasOnly(['name', 'emoji'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 60
          && (
            !('emoji' in request.resource.data)
            || (request.resource.data.emoji is string
                && request.resource.data.emoji.size() <= 8)
          )
        )
        ||
        // Group creator kicks a single other member.
        (
          resource.data.createdBy == request.auth.uid
          && changedKeys().hasOnly(['members'])
          && request.auth.uid in request.resource.data.members
          && request.resource.data.members.size()
             == resource.data.members.size() - 1
          && resource.data.members.hasAll(request.resource.data.members)
        )
      );

      allow delete: if isAdminUser();
    }

    // refreshUsage/{uid}: written ONLY by the refreshPlaceTemp Cloud
    // Function (Admin SDK bypasses these rules). Clients can't touch
    // this collection — it's purely a server-side throttle ledger.
    match /refreshUsage/{uid} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
