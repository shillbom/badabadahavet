rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- helpers --------
    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    function unchanged(field) {
      return !changedKeys().hasAny([field]);
    }
    function validLatLng(lat, lng) {
      return lat is number && lng is number
             && lat >= -90 && lat <= 90
             && lng >= -180 && lng <= 180;
    }

    // ============================================================
    // users/{uid}
    //   Profile + denormalised group list + unlocked achievements.
    //   Only the owner may write. Identity (uid) and createdAt are
    //   immutable. displayName must stay non-empty and bounded.
    // ============================================================
    match /users/{uid} {
      allow read: if signedIn();

      allow create: if isSelf(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() > 0
                    && request.resource.data.displayName.size() <= 40
                    && request.resource.data.groups is list
                    && request.resource.data.groups.size() == 0
                    && request.resource.data.createdAt is number;

      allow update: if isSelf(uid)
                    && unchanged('uid')
                    && unchanged('createdAt')
                    && request.resource.data.uid == uid
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() > 0
                    && request.resource.data.displayName.size() <= 40;

      allow delete: if false;
    }

    // ============================================================
    // places/{id}
    //   World-readable, any signed-in user can create. Lat/lng/name
    //   are validated. After creation, location and provenance are
    //   immutable; only the creator may rename.
    // ============================================================
    match /places/{placeId} {
      allow read: if signedIn();

      allow create: if signedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 80
                    && validLatLng(request.resource.data.lat,
                                   request.resource.data.lng)
                    && request.resource.data.firstSwumAt is number;

      allow update: if signedIn()
                    && resource.data.createdBy == request.auth.uid
                    && unchanged('createdBy')
                    && unchanged('firstSwumAt')
                    && unchanged('lat')
                    && unchanged('lng')
                    && unchanged('id')
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 80;

      allow delete: if false;
    }

    // ============================================================
    // sessions/{id}
    //   World-readable for leaderboards; only the author may write.
    //   Score-affecting fields are bounded on create and frozen on
    //   update so the owner cannot retro-actively inflate points.
    //   Max possible session score: 1 (base) + 2 (new spot) + 2
    //   (winter) = 5. We reject anything outside [1, 5].
    // ============================================================
    match /sessions/{sessionId} {
      allow read: if signedIn();

      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.placeId is string
                    && request.resource.data.placeId.size() > 0
                    && request.resource.data.placeName is string
                    && request.resource.data.placeName.size() <= 80
                    && validLatLng(request.resource.data.lat,
                                   request.resource.data.lng)
                    && request.resource.data.date is number
                    // Lower bound: 2000-01-01. Upper bound: at most one
                    // day in the future, to allow timezone fudge.
                    && request.resource.data.date >= 946684800000
                    && request.resource.data.date <= request.time.toMillis() + 86400000
                    && request.resource.data.points is number
                    && request.resource.data.points >= 1
                    && request.resource.data.points <= 5
                    && request.resource.data.isUniqueForUser is bool
                    && request.resource.data.isWinter is bool
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() <= 40;

      // Owner can edit cosmetic fields (note, photoUrl, displayName).
      // Identity, location, date, and scoring are immutable.
      allow update: if signedIn()
                    && resource.data.uid == request.auth.uid
                    && unchanged('uid')
                    && unchanged('placeId')
                    && unchanged('lat')
                    && unchanged('lng')
                    && unchanged('date')
                    && unchanged('points')
                    && unchanged('isUniqueForUser')
                    && unchanged('isWinter')
                    && unchanged('createdAt');

      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ============================================================
    // groups/{id}
    //   World-readable for joining-by-code. Updates must take one of
    //   three narrow shapes:
    //     1) a non-member adds only themselves to `members`
    //     2) an existing member removes only themselves from `members`
    //     3) the founder renames the group (and changes nothing else)
    //   The code, founder, createdAt, and id can never change.
    // ============================================================
    match /groups/{groupId} {
      allow read: if signedIn();

      allow create: if signedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.members is list
                    && request.resource.data.members.size() == 1
                    && request.resource.data.members[0] == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 60
                    && request.resource.data.code is string
                    && request.resource.data.code.size() >= 3
                    && request.resource.data.code.size() <= 12
                    && request.resource.data.createdAt is number;

      allow update: if signedIn() && (
        // 1) joining: only-self added to members, no other field touched
        (
          changedKeys().hasOnly(['members'])
          && !(request.auth.uid in resource.data.members)
          && request.auth.uid in request.resource.data.members
          && request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.size()
             == resource.data.members.size() + 1
        )
        ||
        // 2) leaving: only-self removed from members
        (
          changedKeys().hasOnly(['members'])
          && request.auth.uid in resource.data.members
          && !(request.auth.uid in request.resource.data.members)
          && resource.data.members.hasAll(request.resource.data.members)
          && request.resource.data.members.size()
             == resource.data.members.size() - 1
        )
        ||
        // 3) founder rename: only `name` changes
        (
          resource.data.createdBy == request.auth.uid
          && changedKeys().hasOnly(['name'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 60
        )
      );

      allow delete: if false;
    }

    // Default deny for any other path.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
